### 8. Configuration — [application.yml](file:///d:/haykhathon/campusride/src/main/resources/application.yml)
```yaml
spring:
  threads:
    virtual:
      enabled: true          # Java 21 Virtual Threads for all request handling
  datasource:
    url: jdbc:postgresql://localhost:5432/campusride
    username: postgres
    password: postgres
  jpa:
    database-platform: org.hibernate.spatial.dialect.postgis.PostgisPG95Dialect
    hibernate.ddl-auto: update
  data.redis:
    host: localhost
    port: 6379
app:
  jwt:
    secret: <generated-secret>
    expiration-ms: 86400000
  ride:
    corridor-radius-meters: 5000   # 5 KM highway corridor
```

